LALE_DESKTOP_URL=http://127.0.0.1:8765

# Formalizer — handles both formalization and proving.
# Default: DeepSeek Prover V2 671B on Novita.
LALE_FORMALIZER_BASE_URL=https://api.novita.ai/openai
LALE_FORMALIZER_MODEL=deepseek/deepseek-prover-v2-671b
# LALE_NOVITA_API_KEY=...

# Alternative formalizer: Goedel Prover V2 32B on Featherless.
# LALE_FORMALIZER_BASE_URL=https://api.featherless.ai/v1
# LALE_FORMALIZER_MODEL=Goedel-LM/Goedel-Prover-V2-32B
# LALE_FEATHERLESS_API_KEY=...

# Auxiliary — informal advisory model (OpenRouter).
LALE_AUXILIARY_MODEL=openai/gpt-chat-latest
# LALE_BASE_URL=https://openrouter.ai/api/v1
# LALE_OPENROUTER_API_KEY=...
