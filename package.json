{
  "name": "lale-next",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first Lean verification for Overleaf",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:ext": "pnpm --filter @lale/extension dev",
    "build:ext": "pnpm --filter @lale/extension build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "desktop:dev": "pnpm --filter @lale/desktop dev",
    "evals": "pnpm --filter @lale/translator evals"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^5.6.3"
  }
}

